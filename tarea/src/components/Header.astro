
<header class="absolute top-0 left-0 w-full z-50">
  <div class="max-w-[1110px] mx-auto px-6 md:px-10 lg:px-0 py-10 md:py-12 flex items-center justify-between">
    <a href="/" class="block z-[60]">
      <img 
  src="/images/logo.svg" 
  alt="Loopstudios" 
  class="h-6 md:h-8 w-auto"
/>
    </a>

    <nav class="hidden md:block">
      <ul class="flex items-center gap-8 lg:gap-10">
        {['About', 'Careers', 'Events', 'Products', 'Support'].map((item) => (
          <li>
            <a href="#" class="text-white text-sm lg:text-base uppercase tracking-widest relative group">
              {item}
              <span class="absolute left-1/2 bottom-[-6px] h-[2px] w-0 bg-white transition-all duration-300 group-hover:w-full group-hover:left-0"></span>
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <button 
      id="menu-btn"
      class="md:hidden z-[60] text-white focus:outline-none"
      aria-label="Toggle menu"
    >
      <img id="menu-icon" src="/public/images/icon-hamburger.svg" 
      alt="Abrir menú" class="w-6 h-5">
    </button>
  </div>

  <div 
    id="mobile-menu" 
    class="fixed inset-0 bg-black z-[55] translate-x-full transition-transform 
    duration-300 md:hidden flex flex-col justify-center px-6"
  >
    <ul class="flex flex-col gap-6">
      {['About', 'Careers', 'Events', 'Products', 'Support'].map((item) => (
        <li>
          <a href="#" class="text-white text-3xl uppercase font-light tracking-widest hover:text-gray-400">
            {item}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  const icon = document.getElementById('menu-icon') as HTMLImageElement;

  btn?.addEventListener('click', () => {
    if (!menu || !icon) return;

    const isClosed = menu.classList.toggle('translate-x-full');
    
  if (isClosed) {
  icon.src = "/images/icon-hamburger.svg"; 
  document.body.classList.remove('overflow-hidden');
} else {
  icon.src = "/images/icon-close.svg"; 
  document.body.classList.add('overflow-hidden');
}
  });
</script>
